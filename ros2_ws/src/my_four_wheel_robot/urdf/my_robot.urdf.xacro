<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="my_robot">

  <!-- ================== THAM SỐ CHUNG - DỄ CHỈNH SỬA Ở ĐÂY ================== -->
  <xacro:property name="base_length" value="0.5"/>      <!-- dài thân xe (x) -->
  <xacro:property name="base_width" value="0.4"/>       <!-- rộng thân xe (y) -->
  <xacro:property name="base_height" value="0.1"/>      <!-- cao thân xe (z) -->
  <xacro:property name="wheel_radius" value="0.05"/>    <!-- bán kính bánh -->
  <xacro:property name="wheel_width" value="0.03"/>     <!-- chiều rộng bánh -->
  <xacro:property name="wheel_mass" value="0.5"/>       <!-- khối lượng mỗi bánh -->

  <!-- Khoảng cách bánh xe - chỉnh ở đây để thay đổi vị trí bánh -->
  <xacro:property name="wheel_x_offset" value="0.2"/>      <!-- khoảng cách từ tâm đến trục trước/sau (0.2m) -->
  <xacro:property name="wheel_separation" value="0.4"/>    <!-- khoảng cách trái-phải giữa hai bánh cùng trục -->

  <!-- ================== BASE_LINK (thân xe) ================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

   <link name="base_footprint"/>
   <joint name="base_joint" type="fixed">
     <parent link="base_footprint"/>
     <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================== 4 BÁNH XE - VIẾT RIÊNG TỪNG CÁI ĐỂ DỄ SỬA ================== -->

  <!-- BÁNH TRƯỚC TRÁI -->
  <link name="left_front_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_front_wheel"/>
    <!-- Vị trí bánh trước trái - chỉnh 3 số xyz ở đây -->
    <origin xyz="${wheel_x_offset} ${wheel_separation/2.0} ${-(base_height/2.0 - wheel_radius)}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- BÁNH TRƯỚC PHẢI -->
  <link name="right_front_wheel">
    <!-- Giống bánh trước trái, chỉ khác tên và vị trí y -->
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_front_wheel"/>
    <!-- Vị trí bánh trước phải - chỉ thay dấu y -->
    <origin xyz="${wheel_x_offset} ${-wheel_separation/2.0} ${-(base_height/2.0 - wheel_radius)}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- BÁNH SAU TRÁI -->
  <link name="left_rear_wheel">
    <!-- Giống bánh trước, chỉ khác vị trí x -->
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_rear_wheel"/>
    <!-- Vị trí bánh sau trái - x âm -->
    <origin xyz="${-wheel_x_offset} ${wheel_separation/2.0} ${-(base_height/2.0 - wheel_radius)}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- BÁNH SAU PHẢI -->
  <link name="right_rear_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_rear_wheel"/>
    <!-- Vị trí bánh sau phải - x âm, y âm -->
    <origin xyz="${-wheel_x_offset} ${-wheel_separation/2.0} ${-(base_height/2.0 - wheel_radius)}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================== ros2_control (giữ nguyên nhưng dùng tên mới cho Jazzy) ================== -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>  <!-- sửa cho Harmonic -->
    </hardware>
    <joint name="left_front_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_rear_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_front_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_rear_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
  </ros2_control>

  <!-- Plugin cho Gazebo Harmonic (sửa tên file .so) -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find my_four_wheel_robot)/config/my_controller.yaml</parameters>
    </plugin>
  </gazebo>

   <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
   </gazebo>

</robot>